## 开发用镜像：前端 8081 + 后端 3000（等价于本地 `npm run dev`）
# 构建：
#   docker build -f Dockerfile.dev -t scalebox-assistant-dev .
# 运行：
#   docker run -p 3000:3000 -p 8081:8081 scalebox-assistant-dev

FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json* .npmrc* ./
RUN npm install

COPY . .

# Metro / Expo 开发模式有大量文件监控，适合小流量开发环境，不建议用于生产。
ENV NODE_ENV=development

EXPOSE 3000 8081

CMD ["npm", "run", "dev"]

